# ----------------------------------------------------------------------
# StoryWeaver — Apache access rules
# Block direct HTTP access to private directories.
# ----------------------------------------------------------------------

Options -Indexes
DirectoryIndex index.php index.html

# Block access to private data directories
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Deny access to _data/
  RewriteRule ^_data/ - [F,L]

  # Deny direct access to raw story node files
  RewriteRule ^stories/ - [F,L]

  # Deny access to quarantine/
  RewriteRule ^quarantine/ - [F,L]

  # Deny direct access to generated/uploaded story images
  RewriteRule ^_assets/images/ - [F,L]

  # Deny access to _mail/
  RewriteRule ^_mail/ - [F,L]

  # Deny access to _lib/
  RewriteRule ^_lib/ - [F,L]

  # Serve extensionless .php and .html URLs for public app pages.
  RewriteCond %{REQUEST_FILENAME} -d [OR]
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  RewriteCond %{REQUEST_FILENAME}.php -f
  RewriteRule ^(.+?)/?$ $1.php [L]

  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# Fallback for servers without mod_rewrite — nested .htaccess files
# deny access to sensitive directories directly.
# (Each directory below should also contain its own .htaccess with "Require all denied"
#  as a defense-in-depth measure.)
